# ============================================================
#  Evera — Unreal Engine .gitignore
#  Ignoriše sve što se GENERIŠE (build artefakti, cache).
#  NE ignoriše: .uproject, Config/, Content/, Source/
# ============================================================

# Unreal generisani folderi
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/

# IDE / editor
.vs/
.idea/
.vscode/
*.sln
*.suo
*.sdf
*.opensdf
*.opendb
*.VC.db
*.VC.VC.opendb
*.xcodeproj
*.xcworkspace

# Prekompajlirani headeri i objekti
*.obj
*.pch
*.pdb
*.exp
*.lib
*.dll
*.exe

# OS smeće
Thumbs.db
Thumbs.db:encryptable
Desktop.ini
.DS_Store
$RECYCLE.BIN/

# Privremeni / backup fajlovi
*.tmp
*.bak
*~

# ============================================================
#  Veliki preuzeti marketplace/Fab asseti (preskupi za GitHub LFS)
#  Ponovo se skidaju s Fab. Kod ima fallback ako fale.
# ============================================================
game/Evera/Content/Megaplant_Library/
game/Evera/Content/Fab/
game/Evera/Content/Medieval_Campfire/
game/Evera/Content/Megaplant/

# Sirove prototype animacije (AI, slab kvalitet, glomazne)
assets/animations/

# CozyNature Fab pack (re-download from Fab; large marketplace asset)
game/Evera/Content/CozyNature/

# Stylized PBR Nature pack (re-download from Fab; large marketplace asset)
game/Evera/Content/Stylized_PBR_Nature/

# More large re-downloadable Fab packs (present locally, rebuilt/re-imported as needed)
game/Evera/Content/Fantastic_Village_Pack/
game/Evera/Content/GV_FreeShrubsPack/
game/Evera/Content/Maxtree/
game/Evera/Content/HighPoly_Tree_Model/
game/Evera/Content/Mobile_Trees/
game/Evera/Content/RPGHeroSquad/
game/Evera/Content/Realistic_Cow/

# Built play map is ~278 MB (rebuildable from the nature pack via script) —
# exceeds GitHub's 100 MB per-file limit, so it is not committed.
game/Evera/Content/Evera/Maps/EveraForest.umap
game/Evera/Content/Evera/Maps/EveraForest/
